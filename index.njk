  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:      #111111;
      --gray-900:   #1a1a1a;
      --gray-700:   #3a3a3a;
      --gray-600:   #555555;
      --gray-400:   #999999;
      --gray-200:   #e8e8e6;
      --gray-100:   #f5f5f3;
      --white:      #ffffff;
      --accent:     #1a56a0;   /* deep navy blue — industrial / expertise */
      --accent-mid: #2563eb;
      --accent-light: #eff6ff;
      --gold:       #c9952a;   /* secondary accent — recovery value / currency */
      --gold-light: #fdf8ee;
      --radius:     6px;
      --max:        1100px;
      --t:          0.2s ease;
    }

    html { scroll-behavior: smooth; scroll-padding-top: 80px; }
    section[id], div[id] { scroll-margin-top: 80px; }

    body {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: var(--black);
      background: var(--white);
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,255,255,0.93);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--gray-200);
      height: 124px;
      display: flex; align-items: center;
    }
    .nav-inner {
      max-width: var(--max); margin: 0 auto; padding: 0 28px;
      width: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      display: flex; flex-direction: column; gap: 1px;
      text-decoration: none;
    }
    .nav-logo-name {
      font-size: 15px; font-weight: 600; letter-spacing: -0.02em; color: var(--black); line-height: 1.1;
    }
    .nav-logo-tag {
      font-size: 10px; font-weight: 400; letter-spacing: 0.04em; color: var(--accent); line-height: 1;
    }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a {
      font-size: 17px; color: var(--gray-600); text-decoration: none;
      font-weight: 700; transition: color var(--t);
    }
    .nav-links a:hover { color: var(--black); }
    .nav-cta { color: var(--accent) !important; font-weight: 500 !important; }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; background: none; border: none; padding: 4px;
    }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--black); border-radius: 2px; transition: all 0.25s; }

    /* ── HERO ── */
    #home {
      padding: 148px 28px 88px;
      max-width: var(--max); margin: 0 auto;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--gold-light); border: 1px solid #e8d9b0;
      border-radius: 20px; padding: 5px 14px;
      font-size: 12px; font-weight: 500; color: var(--gold);
      letter-spacing: 0.03em; margin-bottom: 26px;
    }
    .hero-badge-dot {
      width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0;
    }
    .hero-name {
      font-family: 'Lora', serif;
      font-size: clamp(44px, 6.5vw, 76px);
      font-weight: 600; line-height: 1.05;
      letter-spacing: -0.025em; color: var(--black); margin-bottom: 10px;
    }
    .hero-title {
      font-family: 'Lora', serif;
      font-size: clamp(18px, 2.5vw, 26px);
      font-weight: 400; font-style: italic;
      color: var(--accent); margin-bottom: 28px; line-height: 1.3;
    }
    .hero-sub {
      font-size: clamp(16px, 1.6vw, 18px);
      color: var(--gray-600); max-width: 600px;
      line-height: 1.7; margin-bottom: 42px;
    }
    .hero-sub strong { color: var(--black); font-weight: 500; }
    .btn-group { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 52px; }
    .btn {
      display: inline-block; padding: 13px 26px; border-radius: var(--radius);
      font-size: 14px; font-weight: 500; text-decoration: none;
      transition: all var(--t); cursor: pointer; border: none;
    }
    .btn-primary { background: var(--accent); color: var(--white); }
    .btn-primary:hover { background: #154a8a; transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--black); border: 1.5px solid var(--gray-200); }
    .btn-outline:hover { border-color: var(--black); transform: translateY(-1px); }

    .hero-proof {
      display: flex; flex-wrap: wrap; gap: 32px; padding-top: 32px;
      border-top: 1px solid var(--gray-200);
    }
    .proof-item { display: flex; flex-direction: column; gap: 3px; }
    .proof-number {
      font-family: 'Lora', serif; font-size: 28px; font-weight: 600;
      color: var(--black); line-height: 1;
    }
    .proof-label { font-size: 12px; color: var(--gray-400); line-height: 1.3; max-width: 110px; }

    /* ── SECTION DIVIDER ── */
    .section-divider {
      max-width: var(--max); margin: 0 auto; padding: 0 28px;
      border: none; border-top: 1px solid var(--gray-200);
    }

    /* ── SECTION SHARED ── */
    section { padding: 88px 28px; max-width: var(--max); margin: 0 auto; }
    .section-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--gray-400); margin-bottom: 12px;
    }
    .section-title {
      font-family: 'Lora', serif;
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 600; line-height: 1.15;
      letter-spacing: -0.02em; color: var(--black); margin-bottom: 18px;
    }
    .section-body {
      font-size: 17px; color: var(--gray-600); max-width: 640px; line-height: 1.75;
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid; grid-template-columns: 1fr 420px;
      gap: 64px; align-items: start; margin-top: 52px;
    }
    .about-text p {
      color: var(--gray-600); font-size: 16px; line-height: 1.85; margin-bottom: 18px;
    }
    .about-text p:last-child { margin-bottom: 0; }
    .about-creds {
      display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px;
    }
    .cred-pill {
      font-size: 12px; font-weight: 500; color: var(--accent);
      background: var(--accent-light); border-radius: 20px;
      padding: 5px 12px;
    }
    .about-sidebar { display: flex; flex-direction: column; gap: 16px; }
    .stat-card {
      background: var(--gray-100); border-radius: 10px;
      padding: 24px 22px; display: flex; align-items: flex-start; gap: 16px;
    }
    .stat-icon {
      width: 38px; height: 38px; background: var(--accent-light);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; color: var(--accent);
    }
    .stat-card-content { flex: 1; }
    .stat-number {
      font-family: 'Lora', serif; font-size: 30px; font-weight: 600;
      color: var(--black); line-height: 1; margin-bottom: 4px;
    }
    .stat-label { font-size: 13px; color: var(--gray-600); line-height: 1.4; }
    .about-quote {
      background: var(--accent); border-radius: 10px; padding: 24px 22px; color: var(--white);
    }
    .about-quote-text {
      font-family: 'Lora', serif; font-size: 16px; font-style: italic;
      line-height: 1.6; color: rgba(255,255,255,0.9); margin-bottom: 10px;
    }
    .about-quote-attr { font-size: 12px; color: rgba(255,255,255,0.55); }

    /* ── SERVICES ── */
    #services .section-intro { margin-bottom: 52px; }
    .services-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px;
    }
    .service-card {
      border: 1.5px solid var(--gray-200); border-radius: 12px;
      padding: 30px 26px; transition: all var(--t); cursor: default;
      display: flex; flex-direction: column; gap: 14px;
    }
    .service-card:hover { border-color: var(--accent); box-shadow: 0 4px 24px rgba(26,86,160,0.08); transform: translateY(-2px); }
    .service-card.featured { border-color: var(--accent); background: var(--accent-light); }
    .service-number {
      font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
      color: var(--gray-400); text-transform: uppercase;
    }
    .service-card.featured .service-number { color: var(--accent); }
    .service-tag {
      display: inline-block; font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--white); background: var(--gold);
      padding: 3px 9px; border-radius: 3px;
    }
    .service-card h3 {
      font-size: 17px; font-weight: 600; color: var(--black); line-height: 1.25;
    }
    .service-card p {
      font-size: 14px; color: var(--gray-600); line-height: 1.7; flex: 1;
    }
    .service-outcome {
      padding-top: 14px; border-top: 1px solid var(--gray-200);
      font-size: 13px; color: var(--gray-400);
    }
    .service-card.featured .service-outcome { border-color: #c3d9f5; }
    .service-outcome strong { color: var(--accent); font-weight: 600; display: block; margin-bottom: 2px; }

    /* ── WHO I WORK WITH ── */
    #who { background: var(--gray-900); max-width: 100%; padding: 80px 28px; }
    #who .inner { max-width: var(--max); margin: 0 auto; }
    #who .section-label { color: #5a8cbf; }
    #who .section-title { color: var(--white); margin-bottom: 10px; }
    #who .section-body { color: rgba(255,255,255,0.6); margin-bottom: 48px; }
    .who-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .who-card {
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px; padding: 30px 26px;
    }
    .who-icon {
      width: 44px; height: 44px; background: rgba(37,99,235,0.2);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      color: #60a5fa; margin-bottom: 16px;
    }
    .who-card h3 { font-size: 17px; font-weight: 600; color: var(--white); margin-bottom: 10px; }
    .who-card p { font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.7; }
    .who-card ul { margin: 10px 0 0 0; padding-left: 16px; }
    .who-card ul li { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 5px; line-height: 1.5; }

    /* ── BLOG ── */
    #blog { background: var(--gray-100); max-width: 100%; padding: 88px 28px; }
    #blog .inner { max-width: var(--max); margin: 0 auto; }
    .post-list { margin-top: 48px; }
    .post-item {
      display: grid; grid-template-columns: 90px 1fr;
      gap: 28px; padding: 26px 0;
      border-bottom: 1px solid #e0e0dc;
      text-decoration: none; color: inherit; align-items: start;
      transition: all var(--t);
    }
    .post-item:first-child { border-top: 1px solid #e0e0dc; }
    .post-item:hover .post-title { color: var(--accent); }
    .post-date { font-size: 12px; color: var(--gray-400); padding-top: 3px; line-height: 1.4; }
    .post-tag {
      font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 6px;
    }
    .post-title {
      font-size: 17px; font-weight: 500; color: var(--black);
      margin-bottom: 8px; line-height: 1.35; transition: color var(--t);
    }
    .post-excerpt { font-size: 14px; color: var(--gray-600); line-height: 1.65; }

    /* ── BOOK ── */
    #book { background: var(--black); max-width: 100%; padding: 88px 28px; }
    #book .inner {
      max-width: var(--max); margin: 0 auto;
      display: grid; grid-template-columns: 200px 1fr;
      gap: 60px; align-items: center;
    }
    .book-cover-img {
      width: 100%; max-width: 200px;
      border-radius: 8px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      display: block;
    }
    #book .section-label { color: #5a8cbf; }
    #book .section-title { color: var(--white); }
    .book-description { color: rgba(255,255,255,0.65); font-size: 16px; line-height: 1.8; margin-bottom: 24px; }
    .book-stats { display: flex; gap: 28px; margin-bottom: 28px; }
    .book-stat { font-size: 13px; color: rgba(255,255,255,0.4); }
    .book-stat strong { color: rgba(255,255,255,0.8); font-weight: 500; display: block; margin-bottom: 2px; }
    .btn-amazon {
      background: #ff9900; color: #111;
      display: inline-flex; align-items: center; gap: 10px;
      font-weight: 600; font-size: 14px;
    }
    .btn-amazon:hover { background: #e68900; color: #111; transform: translateY(-1px); }

    /* ── CONTACT ── */
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 64px; align-items: start; margin-top: 52px;
    }
    .contact-text p { color: var(--gray-600); font-size: 16px; line-height: 1.8; margin-bottom: 20px; }
    .contact-links { display: flex; flex-direction: column; gap: 14px; margin-top: 8px; }
    .contact-link {
      display: flex; align-items: center; gap: 12px;
      font-size: 14px; color: var(--gray-600); text-decoration: none; transition: color var(--t);
    }
    .contact-link:hover { color: var(--black); }
    .contact-icon {
      width: 36px; height: 36px; background: var(--gray-100);
      border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .contact-form { display: flex; flex-direction: column; gap: 16px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    label { font-size: 13px; font-weight: 500; color: var(--black); }
    input, textarea, select {
      padding: 11px 14px; border: 1.5px solid var(--gray-200); border-radius: var(--radius);
      font-size: 14px; font-family: 'Inter', sans-serif; color: var(--black);
      background: var(--white); transition: border-color var(--t); outline: none;
    }
    input:focus, textarea:focus, select:focus { border-color: var(--accent); }
    textarea { resize: vertical; min-height: 120px; }
    .form-note { font-size: 12px; color: var(--gray-400); }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--gray-200); padding: 36px 28px; }
    .footer-inner {
      max-width: var(--max); margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
    }
    .footer-left { font-size: 13px; color: var(--gray-400); line-height: 1.6; }
    .footer-right { display: flex; gap: 24px; }
    .footer-right a { font-size: 13px; color: var(--gray-400); text-decoration: none; transition: color var(--t); }
    .footer-right a:hover { color: var(--black); }

    /* ── TOAST ── */
    #toast {
      position: fixed; bottom: 28px; right: 28px;
      background: var(--black); color: var(--white);
      padding: 14px 22px; border-radius: 8px; font-size: 14px;
      opacity: 0; transform: translateY(10px); transition: all 0.3s ease;
      pointer-events: none; z-index: 999;
    }
    #toast.show { opacity: 1; transform: translateY(0); }

    /* ── NAV LOGO IMAGE ── */
    .nav-logo-img {
      height: 90px; width: auto; display: block; max-width: 420px;
    }
    .nav-logo-text-fallback {
      display: flex; flex-direction: column; gap: 1px;
    }

    /* ── HERO 2-COLUMN LAYOUT ── */
    .hero-layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 56px;
      align-items: center;
    }
    .hero-col-text { /* left col — all existing hero content */ }
    .hero-image-wrap {
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
    }
    .hero-headshot {
      width: 100%;
      border-radius: 14px;
      display: block;
      box-shadow: 0 24px 64px rgba(0,0,0,0.13);
      aspect-ratio: 3/4;
      object-fit: cover;
      object-position: top center;
    }
    .hero-tagline-block {
      width: 100%;
      background: var(--accent);
      border-radius: 8px;
      padding: 14px 18px;
      text-align: center;
    }
    .hero-tagline-text {
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      line-height: 1.7;
    }
    .img-placeholder {
      width: 100%;
      background: var(--gray-100);
      border: 2px dashed var(--gray-200);
      border-radius: 14px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      color: var(--gray-400);
      font-size: 12px;
      text-align: center;
      padding: 40px 24px;
      aspect-ratio: 3/4;
    }

    /* ── PORTRAIT IN ABOUT SIDEBAR ── */
    .about-portrait-wrap {
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 16px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    }
    .about-portrait {
      width: 100%; display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
      object-position: top center;
    }
    .about-portrait-placeholder {
      width: 100%;
      aspect-ratio: 1/1;
      background: var(--gray-100);
      border: 2px dashed var(--gray-200);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--gray-400);
      font-size: 12px;
    }

    /* ── CLIENTS BAND ── */
    /* ── CLIENTS + VIDEO BAND ── */
    .clients-band {
      background: var(--white);
      border-top: 1px solid var(--gray-200);
      border-bottom: 1px solid var(--gray-200);
      padding: 64px 28px;
    }
    .clients-band-inner {
      max-width: var(--max); margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      align-items: center;
    }
    /* Left: video column */
    .clients-video-col {}
