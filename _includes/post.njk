<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{{ title }} | Curtis Greve</title>
  <meta name="description" content="{{ meta_description }}" />
  <meta name="author" content="Curtis Greve" />
  <link rel="canonical" href="https://www.cgreve.com{{ page.url }}" />

  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://www.cgreve.com{{ page.url }}" />
  <meta property="og:title" content="{{ title }} | Curtis Greve" />
  <meta property="og:description" content="{{ meta_description }}" />
  <meta property="og:site_name" content="Curtis Greve Consulting" />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ title }} | Curtis Greve" />
  <meta name="twitter:description" content="{{ meta_description }}" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #111111; --gray-900: #1a1a1a; --gray-700: #3a3a3a;
      --gray-600: #555555; --gray-400: #999999; --gray-200: #e8e8e6;
      --gray-100: #f5f5f3; --white: #ffffff;
      --accent: #1a56a0; --accent-mid: #2563eb; --accent-light: #eff6ff;
      --gold: #c9952a; --gold-light: #fdf8ee; --radius: 6px; --max: 1100px; --t: 0.2s ease;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.7; color: var(--black); background: var(--white); -webkit-font-smoothing: antialiased; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.93); backdrop-filter: blur(12px); border-bottom: 1px solid var(--gray-200); height: 124px; display: flex; align-items: center; }
    .nav-inner { max-width: var(--max); margin: 0 auto; padding: 0 28px; width: 100%; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { display: flex; flex-direction: column; gap: 1px; text-decoration: none; }
    .nav-logo-img { height: 90px; width: auto; display: block; max-width: 420px; }
    .nav-logo-text-fallback { display: flex; flex-direction: column; gap: 1px; }
    .nav-logo-name { font-size: 15px; font-weight: 600; letter-spacing: -0.02em; color: var(--black); line-height: 1.1; }
    .nav-logo-tag { font-size: 10px; font-weight: 400; letter-spacing: 0.04em; color: var(--accent); line-height: 1; }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { font-size: 17px; color: var(--gray-600); text-decoration: none; font-weight: 700; transition: color var(--t); }
    .nav-links a:hover { color: var(--black); }
    .nav-cta { color: var(--accent) !important; font-weight: 500 !important; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--black); border-radius: 2px; transition: all 0.25s; }

    /* POST LAYOUT */
    .post-wrapper { max-width: 760px; margin: 0 auto; padding: 160px 28px 88px; }
    .post-back { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--gray-400); text-decoration: none; margin-bottom: 32px; transition: color var(--t); }
    .post-back:hover { color: var(--black); }
    .post-back svg { flex-shrink: 0; }
    .post-meta-top { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
    .post-category-pill { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--white); background: var(--accent); padding: 4px 12px; border-radius: 20px; }
    .post-date-top { font-size: 13px; color: var(--gray-400); }
    .post-title-h1 { font-family: 'Lora', serif; font-size: clamp(26px, 4vw, 40px); font-weight: 600; line-height: 1.15; letter-spacing: -0.02em; color: var(--black); margin-bottom: 28px; }
    .post-body { font-size: 17px; color: var(--gray-600); line-height: 1.85; }
    .post-body p { margin-bottom: 22px; }
    .post-body h2 { font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: var(--black); margin: 40px 0 16px; line-height: 1.3; }
    .post-body h3 { font-size: 18px; font-weight: 600; color: var(--black); margin: 32px 0 12px; }
    .post-body strong { color: var(--black); font-weight: 600; }
    .post-body ul, .post-body ol { padding-left: 24px; margin-bottom: 22px; }
    .post-body li { margin-bottom: 8px; }
    .post-body a { color: var(--accent); text-decoration: underline; }
    .post-divider { max-width: 760px; margin: 0 auto 48px; padding: 0 28px; border: none; border-top: 1px solid var(--gray-200); }
    .post-cta-block { max-width: 760px; margin: 0 auto 88px; padding: 0 28px; }
    .post-cta-inner { background: var(--accent-light); border: 1.5px solid #c3d9f5; border-radius: 12px; padding: 32px 36px; display: flex; flex-direction: column; gap: 14px; }
    .post-cta-inner h3 { font-size: 18px; font-weight: 600; color: var(--black); }
    .post-cta-inner p { font-size: 15px; color: var(--gray-600); line-height: 1.7; }
    .btn { display: inline-block; padding: 13px 26px; border-radius: var(--radius); font-size: 14px; font-weight: 500; text-decoration: none; transition: all var(--t); }
    .btn-primary { background: var(--accent); color: var(--white); }
    .btn-primary:hover { background: #154a8a; transform: translateY(-1px); }

    /* FOOTER */
    footer { border-top: 1px solid var(--gray-200); padding: 36px 28px; }
    .footer-inner { max-width: var(--max); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .footer-left { font-size: 13px; color: var(--gray-400); line-height: 1.6; }
    .footer-right { display: flex; gap: 24px; }
    .footer-right a { font-size: 13px; color: var(--gray-400); text-decoration: none; transition: color var(--t); }
    .footer-right a:hover { color: var(--black); }

    @media (max-width: 680px) {
      .nav-links { display: none; flex-direction: column; gap: 20px; position: absolute; top: 62px; left: 0; right: 0; background: var(--white); border-bottom: 1px solid var(--gray-200); padding: 24px 28px; }
      .nav-links.open { display: flex; }
      .hamburger { display: flex; }
      .footer-inner { flex-direction: column; gap: 16px; align-items: flex-start; }
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/images/logo-wide.png" class="nav-logo-img" alt="Curtis Greve LLC"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
      <span class="nav-logo-text-fallback" style="display:none">
        <span class="nav-logo-name">Curtis Greve</span>
        <span class="nav-logo-tag">Reverse Logistics &amp; Liquidation Expert</span>
      </span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/#about">About</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/#who">Who I Help</a></li>
      <li><a href="/blog/">Insights</a></li>
      <li><a href="/#book">Book</a></li>
      <li><a href="/#contact" class="nav-cta">Work With Me</a></li>
    </ul>
    <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="post-wrapper">
  <a href="/blog/" class="post-back">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    Back to Insights
  </a>
  <div class="post-meta-top">
    <span class="post-category-pill">{{ category }}</span>
    <span class="post-date-top">{{ page.date | readableDate }}</span>
  </div>
  <h1 class="post-title-h1">{{ title }}</h1>
  <div class="post-body">
    {{ content | safe }}
  </div>
</div>

<hr class="post-divider" />

<div class="post-cta-block">
  <div class="post-cta-inner">
    <h3>Want to talk through what this means for your operation?</h3>
    <p>I work with retailers, manufacturers, and liquidators on exactly these issues — program assessment, recovery optimization, and building programs that perform at best-in-class levels. Reach out directly.</p>
    <a href="/#contact" class="btn btn-primary">Work With Me</a>
  </div>
</div>

<footer>
  <div class="footer-inner">
    <div class="footer-left">
      <img src="/images/logo-wide.png" alt="Curtis Greve LLC"
           style="height:28px;width:auto;display:block;margin-bottom:8px;opacity:0.7"
           onerror="this.style.display='none'">
      &copy; 2026 Curtis Greve LLC. All rights reserved.<br />
      <span style="font-size:12px;">Recover More. Move Faster. Protect Margin.</span>
    </div>
    <div class="footer-right">
      <a href="/#about">About</a>
      <a href="/#services">Services</a>
      <a href="/blog/">Insights</a>
      <a href="/#book">Book</a>
      <a href="mailto:curtis@cgreve.com">Email</a>
    </div>
  </div>
</footer>

<script>
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  hamburger.addEventListener('click', () => navLinks.classList.toggle('open'));
  navLinks.querySelectorAll('a').forEach(l => l.addEventListener('click', () => navLinks.classList.remove('open')));
</script>
</body>
</html>
